<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for hardened runtime on macOS -->

    <!-- Allow loading unsigned frameworks (PyInstaller bundles) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow JIT compilation (needed by numpy/scipy) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Allow loading dynamic libraries from outside the app bundle -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Network access for license verification -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- File access for user data import/export -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
