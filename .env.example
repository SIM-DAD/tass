# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Lemon Squeezy API key (from LS Dashboard → API → Create API key)
TASS_LS_API_KEY=

# Supabase project URL and anon/publishable key
TASS_SUPABASE_URL=https://jpzgrvpcxsyuitkyhikl.supabase.co
# Supabase anon key — safe to embed in client apps (RLS enforces access, not this key)
TASS_SUPABASE_ANON_KEY=

# SMTP credentials for opt-in crash reports (optional; falls back to local log)
TASS_SMTP_USER=
TASS_SMTP_PASS=
